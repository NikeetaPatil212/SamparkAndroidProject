<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- ── TOOLBAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#2E7D32"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:elevation="6dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/outline_arrow_back_24"
            android:tint="#FFFFFF"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="4dp"
            android:text="Study Material Distribution Report"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStudentCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#1B5E20"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ── SCROLL CONTENT ── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="24dp">

            <!-- ══ FILTERS CARD ══ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="#2E7D32"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/baseline_article_24"
                            android:tint="#FFFFFF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Filters"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <!-- Row 1: Course + Batch -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="10dp">

                            <!-- Course -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginEnd="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Course Name"
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="4dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="46dp"
                                    android:background="@drawable/bg_edittext_outline"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:paddingStart="10dp"
                                    android:paddingEnd="4dp">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/outline_book_2_24"
                                        android:tint="#2E7D32"
                                        android:layout_marginEnd="6dp" />

                                    <Spinner
                                        android:id="@+id/spCourse"
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:background="@null"
                                        android:spinnerMode="dropdown" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- Batch -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Batch Name"
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="4dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="46dp"
                                    android:background="@drawable/bg_edittext_outline"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:paddingStart="10dp"
                                    android:paddingEnd="4dp">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/outline_book_2_24"
                                        android:tint="#2E7D32"
                                        android:layout_marginEnd="6dp" />

                                    <Spinner
                                        android:id="@+id/spBatch"
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:background="@null"
                                        android:spinnerMode="dropdown" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Row 2: Batch Time -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Batch Time"
                                android:textColor="#2E7D32"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="4dp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="46dp"
                                android:background="@drawable/bg_edittext_outline"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="10dp"
                                android:paddingEnd="4dp">

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/outline_book_2_24"
                                    android:tint="#2E7D32"
                                    android:layout_marginEnd="6dp" />

                                <Spinner
                                    android:id="@+id/spTiming"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:background="@null"
                                    android:spinnerMode="dropdown" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Row 3: View toggle — Pending / Distributed -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />

                        <RadioGroup
                            android:id="@+id/rgView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <RadioButton
                                android:id="@+id/rbPending"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Pending"
                                android:textSize="12sp"
                                android:checked="true"
                                android:buttonTint="#2E7D32" />

                            <RadioButton
                                android:id="@+id/rbDistributed"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Distributed"
                                android:textSize="12sp"
                                android:buttonTint="#2E7D32" />
                        </RadioGroup>

                        <!-- Button: View Students -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnViewStudents"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:backgroundTint="#2E7D32"
                            android:text="View Students"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textAllCaps="false"
                            android:insetTop="0dp"
                            android:insetBottom="0dp" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ STUDENT LIST CARD ══ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardStudentList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="#2E7D32"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_person_foreground"
                            android:tint="#FFFFFF" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="Study Material List"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="#FFFFFF"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp" />
                    </LinearLayout>

                    <!-- Horizontal scrollable table -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:minWidth="960dp">

                            <!-- Header Row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:background="#E8F5E9"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView android:layout_width="70dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Adm ID"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="90dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Adm Date"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="150dp" android:layout_height="match_parent"
                                    android:gravity="center_vertical" android:paddingStart="8dp"
                                    android:text="Student Name"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="110dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Mobile"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="90dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Location"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="100dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Course"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="100dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Batch"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="130dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Study Material"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="110dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Distribution Date"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />

                            </LinearLayout>

                            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#CCCCCC" />

                            <!-- Data rows -->
                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rvStudyMaterial"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:nestedScrollingEnabled="false" />

                        </LinearLayout>
                    </HorizontalScrollView>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ EXPORT BUTTON ══ -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGeneratePdf"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="4dp"
                android:backgroundTint="#2E7D32"
                android:text="Export to PDF"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── LOADER ── -->
    <FrameLayout
        android:id="@+id/loaderLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center" />
    </FrameLayout>

</LinearLayout>