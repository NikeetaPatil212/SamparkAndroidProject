<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- ROW -->
    <LinearLayout
        android:id="@+id/rowContainer"
        android:layout_width="wrap_content"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground">

        <!-- Sr No -->
        <TextView
            android:id="@+id/tvInquiryId"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingHorizontal="4dp"
            android:textColor="#888888"
            android:textSize="12sp" />

        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE"/>

        <!-- Student Name -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="140dp"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:textColor="#1A1A1A"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE"/>

        <!-- Mobile -->
        <TextView
            android:id="@+id/tvMobile"
            android:layout_width="110dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:textColor="#444444"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE"/>

        <!-- Inquiry About (tvCourses in adapter) -->
        <TextView
            android:id="@+id/tvCourses"
            android:layout_width="130dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:textColor="#444444"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE"/>

        <!-- Inquiry Date -->
        <TextView
            android:id="@+id/tvInquiryDate"
            android:layout_width="110dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:textColor="#444444"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE"/>

        <!-- Reminder Date (tvFollowUp in adapter) -->
        <TextView
            android:id="@+id/tvFollowUp"
            android:layout_width="110dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:textColor="#444444"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE"/>

        <!-- Address -->
        <TextView
            android:id="@+id/tvAddress"
            android:layout_width="120dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:textColor="#444444"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE"/>

        <!-- Type (tvType in adapter — always "Inquiry") -->
        <TextView
            android:id="@+id/tvType"
            android:layout_width="80dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:textColor="#2E7D32"
            android:textSize="12sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE"/>

        <!-- Feedback -->
        <TextView
            android:id="@+id/tvFeedback"
            android:layout_width="120dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:textColor="#444444"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE"/>

        <!-- Action Button (btnStatus in adapter) -->
        <LinearLayout
            android:layout_width="80dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingHorizontal="6dp">

            <Button
                android:id="@+id/btnStatus"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:backgroundTint="#2E7D32"
                android:text="Action"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textAllCaps="false"
                android:paddingHorizontal="8dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Row bottom divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE" />

</LinearLayout>