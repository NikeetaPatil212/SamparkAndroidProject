<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#2E7D32"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:elevation="6dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/outline_arrow_back_24"
            android:tint="#FFFFFF"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="4dp"
            android:text="Batch Timings"
            android:textColor="#FFFFFF"
            android:textSize="19sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="24dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="#2E7D32"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/baseline_article_24"
                            android:tint="#FFFFFF" />

                        <TextView
                            android:id="@+id/tvFormTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Add Batch Time"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Batch Time *"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/etDescription"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:hint="Example: Morning 7 AM"
                            android:inputType="text"
                            android:maxLines="1"
                            android:paddingHorizontal="12dp"
                            android:singleLine="true"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#AAAAAA"
                            android:textSize="14sp"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="For example: 10 am, Morning First, Girls Only etc"
                            android:textColor="#E57373"
                            android:visibility="gone"
                            android:textSize="11sp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Capacity *"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/etCapacity"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:hint="Enter capacity"
                            android:inputType="number"
                            android:maxLines="1"
                            android:paddingHorizontal="12dp"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#AAAAAA"
                            android:textSize="14sp"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Start Time *"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/etStartTime"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:clickable="true"
                            android:cursorVisible="false"
                            android:focusable="false"
                            android:hint="Tap to select start time"
                            android:inputType="none"
                            android:paddingHorizontal="12dp"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#AAAAAA"
                            android:textSize="14sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Format: 10.00 AM"
                            android:textColor="#E57373"
                            android:textSize="11sp"
                            android:visibility="gone"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="End Time *"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/etEndTime"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:clickable="true"
                            android:cursorVisible="false"
                            android:focusable="false"
                            android:hint="Tap to select end time"
                            android:inputType="none"
                            android:paddingHorizontal="12dp"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#AAAAAA"
                            android:textSize="14sp"
                            android:layout_marginBottom="16dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnSave"
                                android:layout_width="0dp"
                                android:layout_height="50dp"
                                android:layout_weight="1"
                                android:backgroundTint="#2E7D32"
                                android:text="Save"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnUpdate"
                                android:layout_width="0dp"
                                android:layout_height="50dp"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:backgroundTint="#2E7D32"
                                android:text="Update"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:visibility="gone" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnCancelEdit"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="50dp"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:text="Cancel"
                                android:textAllCaps="false"
                                android:textColor="#C62828"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:visibility="gone"
                                app:strokeColor="#C62828" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="#2E7D32"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/outline_full_stacked_bar_chart_24"
                            android:tint="#FFFFFF" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="Timing Details"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvTimeCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="#FFFFFF"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fillViewport="false"
                        android:scrollbars="horizontal">

                        <LinearLayout
                            android:layout_width="610dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="610dp"
                                android:layout_height="40dp"
                                android:background="#E8F5E9"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="36dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="Sr"
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />

                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#DDDDDD" />

                                <TextView
                                    android:layout_width="160dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center_vertical"
                                    android:paddingHorizontal="8dp"
                                    android:text="Batch Time"
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />

                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#DDDDDD" />

                                <TextView
                                    android:layout_width="92dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="Start"
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />

                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#DDDDDD" />

                                <TextView
                                    android:layout_width="92dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="End"
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />

                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#DDDDDD" />

                                <TextView
                                    android:layout_width="70dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="Cap."
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />

                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#DDDDDD" />

                                <TextView
                                    android:layout_width="70dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="Filled"
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />

                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#DDDDDD" />

                                <TextView
                                    android:layout_width="90dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="Free"
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <View
                                android:layout_width="610dp"
                                android:layout_height="1dp"
                                android:background="#DDDDDD" />

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rvBatchTimes"
                                android:layout_width="610dp"
                                android:layout_height="wrap_content"
                                android:nestedScrollingEnabled="false" />
                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <FrameLayout
        android:id="@+id/loaderLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center" />
    </FrameLayout>
</LinearLayout>
