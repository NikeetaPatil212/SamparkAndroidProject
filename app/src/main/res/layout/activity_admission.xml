<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- ── TOOLBAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#2E7D32"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:elevation="6dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/outline_arrow_back_24"
            android:tint="#FFFFFF"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="4dp"
            android:text="Admission"
            android:textColor="#FFFFFF"
            android:textSize="19sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ── SCROLL CONTENT ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="24dp">

            <!-- ══ CARD 1: ADMISSION DETAILS ══ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="#2E7D32"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_person_foreground"
                            android:tint="#FFFFFF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Admission Details"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <!-- Student Name (read-only) -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Student Name"
                            android:textColor="#888888"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp" />

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/tvStudentName"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:hint="Student name"
                            android:focusable="false"
                            android:editable="false"
                            android:paddingHorizontal="12dp"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#AAAAAA"
                            android:textSize="14sp"
                            android:maxLines="1"
                            android:layout_marginBottom="10dp" />

                        <!-- Admission Date -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Admission Date *"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etAdmissionDate"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@null"
                                android:hint="Tap to select date"
                                android:focusable="false"
                                android:textColor="#1A1A1A"
                                android:textColorHint="#AAAAAA"
                                android:textSize="14sp"
                                android:maxLines="1" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/baseline_calendar_today_24"
                                android:tint="#2E7D32" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ CARD 2: COURSE & BATCH ══ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="#2E7D32"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/baseline_article_24"
                            android:tint="#FFFFFF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Course &amp; Batch"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <!-- Course Dropdown -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Course Name *"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="12dp"
                            android:paddingEnd="8dp"
                            android:layout_marginBottom="10dp">

                            <AutoCompleteTextView
                                android:id="@+id/spCourse"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@null"
                                android:hint="Select course"
                                android:textColor="#1A1A1A"
                                android:textColorHint="#AAAAAA"
                                android:textSize="14sp"
                                android:maxLines="1"
                                android:inputType="none"
                                android:cursorVisible="false" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/outline_arrow_drop_down_24"
                                android:tint="#2E7D32" />
                        </LinearLayout>

                        <!-- Batch Dropdown -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Batch Name *"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="12dp"
                            android:paddingEnd="8dp"
                            android:layout_marginBottom="4dp">

                            <AutoCompleteTextView
                                android:id="@+id/spBatch"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@null"
                                android:hint="Select batch (choose course first)"
                                android:textColor="#1A1A1A"
                                android:textColorHint="#AAAAAA"
                                android:textSize="14sp"
                                android:maxLines="1"
                                android:inputType="none"
                                android:cursorVisible="false"
                                android:enabled="false" />

                            <ImageView
                                android:id="@+id/ivBatchArrow"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/outline_arrow_drop_down_24"
                                android:tint="#AAAAAA" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvBatchHelper"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="  ℹ️ Select a course first to load batches"
                            android:textColor="#AAAAAA"
                            android:textSize="10sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ CARD 3: FEE DETAILS ══ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="#2E7D32"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/baseline_call_24"
                            android:tint="#FFFFFF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Fee Details"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <!-- Total Fee -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Fees *"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:layout_marginBottom="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹"
                                android:textColor="#2E7D32"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginEnd="8dp" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="20dp"
                                android:background="#DDDDDD"
                                android:layout_marginEnd="8dp" />

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etTotalFee"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@null"
                                android:hint="Enter total fees"
                                android:inputType="number"
                                android:textColor="#1A1A1A"
                                android:textColorHint="#AAAAAA"
                                android:textSize="14sp"
                                android:maxLines="1" />
                        </LinearLayout>

                        <!-- Paid Fee -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Paid Fee *"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:layout_marginBottom="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹"
                                android:textColor="#2E7D32"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginEnd="8dp" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="20dp"
                                android:background="#DDDDDD"
                                android:layout_marginEnd="8dp" />

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPaidFee"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@null"
                                android:hint="Enter paid amount"
                                android:inputType="number"
                                android:textColor="#1A1A1A"
                                android:textColorHint="#AAAAAA"
                                android:textSize="14sp"
                                android:maxLines="1" />
                        </LinearLayout>

                        <!-- Remaining Fee -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Remaining Fee"
                            android:textColor="#888888"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:layout_marginBottom="4dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹"
                                android:textColor="#AAAAAA"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginEnd="8dp" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="20dp"
                                android:background="#DDDDDD"
                                android:layout_marginEnd="8dp" />

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etRemainingFee"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@null"
                                android:hint="Auto calculated"
                                android:enabled="false"
                                android:textColor="#888888"
                                android:textColorHint="#AAAAAA"
                                android:textSize="14sp"
                                android:maxLines="1" />
                        </LinearLayout>

                        <!-- etReceiptNo hidden -->
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etReceiptNo"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:hint="Receipt number"
                            android:inputType="number"
                            android:paddingHorizontal="12dp"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#AAAAAA"
                            android:textSize="14sp"
                            android:maxLines="1"
                            android:visibility="gone" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ ADD COURSE / CAMERA BUTTONS ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAdd"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:backgroundTint="#2E7D32"
                    android:text="+ Add Course"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textAllCaps="false"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCamera"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="#2E7D32"
                    android:text="📷 Camera"
                    android:textColor="#2E7D32"
                    android:textSize="13sp"
                    android:textAllCaps="false"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Photo info -->
            <TextView
                android:id="@+id/tvPhotoInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:textSize="13sp"
                android:textColor="#555555"
                android:visibility="gone" />

            <!-- ══ CARD 4: COURSE ENROLLMENT TABLE ══ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="#2E7D32"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/baseline_article_24"
                            android:tint="#FFFFFF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Course Enrollment"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Horizontally scrollable table -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- TABLE HEADER — widths must exactly match item_admission_detail.xml -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="42dp"
                                android:orientation="horizontal"
                                android:background="#E8F5E9"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="130dp"
                                    android:layout_height="wrap_content"
                                    android:paddingHorizontal="8dp"
                                    android:text="Course Name"
                                    android:textColor="#2E7D32"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />

                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC"/>

                                <TextView
                                    android:layout_width="80dp"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Course ID"
                                    android:textColor="#2E7D32"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />

                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC"/>

                                <TextView
                                    android:layout_width="120dp"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Batch Name"
                                    android:textColor="#2E7D32"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />

                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC"/>

                                <TextView
                                    android:layout_width="90dp"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Total Fee"
                                    android:textColor="#2E7D32"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />

                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC"/>

                                <TextView
                                    android:layout_width="90dp"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Paid Fee"
                                    android:textColor="#2E7D32"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />

                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC"/>

                                <TextView
                                    android:layout_width="110dp"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Remaining"
                                    android:textColor="#2E7D32"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />

                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC"/>

                                <TextView
                                    android:layout_width="80dp"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Batch ID"
                                    android:textColor="#2E7D32"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- TABLE BODY — RecyclerView rows -->
                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rvFeeDetails"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:nestedScrollingEnabled="false" />

                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ CARD 5: SUMMARY ══ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="#2E7D32"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/baseline_article_24"
                            android:tint="#FFFFFF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Summary"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Fee"
                            android:textColor="#888888"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp" />

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSummaryTotalFee"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:hint="Total fee"
                            android:enabled="false"
                            android:paddingHorizontal="12dp"
                            android:textColor="#888888"
                            android:textColorHint="#AAAAAA"
                            android:textSize="14sp"
                            android:maxLines="1"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Paid Fee"
                            android:textColor="#888888"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp" />

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSummaryPaidFee"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:hint="Paid fee"
                            android:enabled="false"
                            android:paddingHorizontal="12dp"
                            android:textColor="#888888"
                            android:textColorHint="#AAAAAA"
                            android:textSize="14sp"
                            android:maxLines="1"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Remaining Fee"
                            android:textColor="#888888"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp" />

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSummaryRemainingFee"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:hint="Remaining fee"
                            android:enabled="false"
                            android:paddingHorizontal="12dp"
                            android:textColor="#888888"
                            android:textColorHint="#AAAAAA"
                            android:textSize="14sp"
                            android:maxLines="1"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Receipt No *"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSummaryReceiptNo"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:hint="Enter receipt number"
                            android:inputType="text"
                            android:paddingHorizontal="12dp"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#AAAAAA"
                            android:textSize="14sp"
                            android:maxLines="1"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Reminder Date"
                            android:textColor="#888888"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:layout_marginBottom="10dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etReminderDate"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@null"
                                android:hint="Tap to set reminder"
                                android:focusable="false"
                                android:clickable="true"
                                android:textColor="#1A1A1A"
                                android:textColorHint="#AAAAAA"
                                android:textSize="14sp"
                                android:maxLines="1" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/baseline_calendar_today_24"
                                android:tint="#2E7D32" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ FINISH BUTTON ══ -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFinish"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:backgroundTint="#2E7D32"
                android:text="Finish"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

    <!-- ── LOADER OVERLAY ── -->
    <FrameLayout
        android:id="@+id/loaderLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center" />
    </FrameLayout>

</LinearLayout>