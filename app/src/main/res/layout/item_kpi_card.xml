<?xml version="1.0" encoding="utf-8"?>
<!-- Full-width single card — PagerSnapHelper snaps one at a time -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="170dp"
    android:layout_marginHorizontal="16dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp">

    <!-- Gradient background set programmatically -->
    <FrameLayout
        android:id="@+id/flGradientBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Big faded emoji watermark — bottom right -->
        <TextView
            android:id="@+id/tvWatermark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="4dp"
            android:text="📄"
            android:textSize="90sp"
            android:alpha="0.12" />

        <!-- Main content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="18dp"
            android:paddingBottom="16dp">

            <!-- Row 1: Pill label + position counter -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <!-- Pill -->
                <TextView
                    android:id="@+id/tvPill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INQUIRIES"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:background="@drawable/bg_kpi_pill"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="5dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <!-- "3 of 8" counter -->
                <TextView
                    android:id="@+id/tvPosition"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 of 8"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:alpha="0.70"
                    android:background="@drawable/bg_kpi_pill"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp" />
            </LinearLayout>

            <!-- Big value -->
            <TextView
                android:id="@+id/tvValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#FFFFFF"
                android:textSize="46sp"
                android:textStyle="bold"
                android:includeFontPadding="false"
                android:layout_marginBottom="6dp" />

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Title"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subtitle"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:alpha="0.72"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Thin bottom accent line -->
        <View
            android:layout_width="48dp"
            android:layout_height="3dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="22dp"
            android:layout_marginBottom="14dp"
            android:background="#33FFFFFF" />

    </FrameLayout>
</androidx.cardview.widget.CardView>