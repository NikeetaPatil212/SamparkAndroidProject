<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- ── TOOLBAR ── -->
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="60dp"
        android:background="#2E7D32" android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp" android:paddingEnd="16dp" android:elevation="6dp">

        <ImageButton android:id="@+id/btnBack"
            android:layout_width="44dp" android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/outline_arrow_back_24"
            android:tint="#FFFFFF" android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:paddingStart="4dp"
            android:text="Outstanding Fees Detailed Report"
            android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" />

        <TextView android:id="@+id/tvTotalBadge"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold"
            android:paddingHorizontal="10dp" android:paddingVertical="4dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ── SCROLL ── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp" android:paddingTop="14dp" android:paddingBottom="24dp">

            <!-- ── FILTER CARD (no date range) ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="12dp" app:cardElevation="3dp" app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
                        android:background="#2E7D32" android:gravity="center_vertical"
                        android:paddingHorizontal="14dp" android:orientation="horizontal">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/outline_filter_alt_24"
                            android:tint="#FFFFFF" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="8dp" android:text="Apply Filters"
                            android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="12dp">

                        <!-- Row 1: Course / Batch -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="10dp">
                            <Spinner android:id="@+id/spinnerCourse"
                                android:layout_width="0dp" android:layout_height="44dp"
                                android:layout_weight="1" android:layout_marginEnd="6dp"
                            android:popupBackground="#FFFFFF" />
                            <Spinner android:id="@+id/spinnerBatch"
                                android:layout_width="0dp" android:layout_height="44dp"
                                android:layout_weight="1"
                                android:popupBackground="#FFFFFF" />
                        </LinearLayout>

                        <!-- Row 2: Time -->
                        <Spinner android:id="@+id/spinnerTime"
                            android:layout_width="match_parent" android:layout_height="44dp"
                            android:layout_marginBottom="10dp"
                            android:popupBackground="#FFFFFF" />

                        <!-- Row 3: Student Name -->
                        <EditText android:id="@+id/etStudentName"
                            android:layout_width="match_parent" android:layout_height="44dp"
                            android:hint="Student Name" android:textSize="13sp"
                            android:paddingHorizontal="12dp"
                            android:layout_marginBottom="10dp" android:inputType="textPersonName" />

                        <!-- Row 4: Contact / Location -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="12dp">
                            <EditText android:id="@+id/etContactNo"
                                android:layout_width="0dp" android:layout_height="44dp"
                                android:layout_weight="1" android:layout_marginEnd="6dp"
                                android:hint="Contact No" android:textSize="13sp" android:inputType="phone"
                                android:paddingHorizontal="12dp"  />
                            <EditText android:id="@+id/etLocation"
                                android:layout_width="0dp" android:layout_height="44dp"
                                android:layout_weight="1"
                                android:hint="Location" android:textSize="13sp"
                                android:paddingHorizontal="12dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnReset"
                                android:layout_width="0dp"
                                android:layout_height="46dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="8dp"
                                android:text="Reset"
                                android:textAllCaps="false"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:backgroundTint="#757575"/>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnViewStudents"
                                android:layout_width="0dp"
                                android:layout_height="46dp"
                                android:layout_weight="2"
                                android:text="View Students"
                                android:textAllCaps="false"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:backgroundTint="#2E7D32"/>

                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── TABLE CARD ── -->
            <androidx.cardview.widget.CardView android:id="@+id/cardTable"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="12dp" app:cardElevation="3dp" app:cardBackgroundColor="#FFFFFF"
                android:visibility="gone">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
                        android:background="#2E7D32" android:gravity="center_vertical"
                        android:paddingHorizontal="14dp" android:orientation="horizontal">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/baseline_article_24" android:tint="#FFFFFF" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginStart="8dp"
                            android:text="Outstanding Students"
                            android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" />
                        <CheckBox android:id="@+id/cbSelectAll"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Select All" android:textColor="#FFFFFF" android:textSize="11sp"
                            android:buttonTint="#FFFFFF" />
                    </LinearLayout>

                    <HorizontalScrollView
                        android:layout_width="match_parent" android:layout_height="wrap_content">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- Table Header -->
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="40dp"
                                android:background="#E8F5E9" android:gravity="center_vertical"
                                android:orientation="horizontal" android:paddingHorizontal="0dp">
                                <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                                    android:gravity="center" android:text="No" android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <TextView android:layout_width="60dp" android:layout_height="wrap_content"
                                    android:gravity="center" android:text="Select" android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                                    android:gravity="center" android:text="Adm. Date" android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <TextView android:layout_width="150dp" android:layout_height="wrap_content"
                                    android:gravity="center" android:text="Student Name" android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <TextView android:layout_width="110dp" android:layout_height="wrap_content"
                                    android:gravity="center" android:text="Mobile" android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                                    android:gravity="center" android:text="Location" android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                                    android:gravity="center" android:text="Course" android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                                    android:gravity="center" android:text="Batch" android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                                    android:gravity="center" android:text="Batch Time" android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                                    android:gravity="center" android:text="Fees" android:textColor="#1565C0" android:textSize="11sp" android:textStyle="bold" />
                                <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                                    android:gravity="center" android:text="Paid" android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                                    android:gravity="center" android:text="Outstanding" android:textColor="#C62828" android:textSize="11sp" android:textStyle="bold" />
                                <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                                    android:gravity="center" android:text="Due Date" android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />

                            </LinearLayout>
                            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#CCCCCC" />

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rvOutstanding"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:nestedScrollingEnabled="false"
                                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <!-- ── EMPTY STATE ── -->
            <TextView android:id="@+id/tvEmptyState"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="No outstanding records found"
                android:textColor="#888888" android:textSize="14sp" android:gravity="center"
                android:padding="30dp" android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── FOOTER: TOTALS + ACTIONS ── -->
    <LinearLayout android:id="@+id/llFooter"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="#FFFFFF"
        android:padding="10dp" android:elevation="8dp" android:visibility="gone">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:id="@+id/tvTotalFees"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:background="@drawable/bg_stat_blue" android:padding="8dp" android:layout_marginEnd="4dp"
                android:text="Total Fees ₹0" android:textColor="#1565C0" android:textSize="11sp" android:textStyle="bold" android:gravity="center"/>
            <TextView android:id="@+id/tvTotalPaid"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:background="@drawable/bg_stat_green" android:padding="8dp" android:layout_marginEnd="4dp"
                android:text="Total Paid ₹0" android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" android:gravity="center"/>
            <TextView android:id="@+id/tvTotalOutstanding"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:background="@drawable/bg_stat_red" android:padding="8dp"
                android:text="Outstanding ₹0" android:textColor="#C62828" android:textSize="11sp" android:textStyle="bold" android:gravity="center"/>
        </LinearLayout>

        <!-- ══ SEND BUTTONS ROW ══ -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendWhatsappMessage"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#25D366"
                android:textColor="#FFFFFF"
                android:text="📱 WhatsApp"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textAllCaps="false"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendSMSMessage"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#25D366"
                android:textColor="#FFFFFF"
                android:text="✉ Send SMS"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textAllCaps="false"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExportToPdf"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:backgroundTint="#25D366"
                android:textColor="#FFFFFF"
                android:text="Generate PDF"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textAllCaps="false"/>

        </LinearLayout>

    </LinearLayout>

    <!-- ── LOADER ── -->
    <FrameLayout android:id="@+id/loaderLayout"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#80000000" android:visibility="gone">
        <ProgressBar android:layout_width="56dp" android:layout_height="56dp"
            android:layout_gravity="center" />
    </FrameLayout>

</LinearLayout>