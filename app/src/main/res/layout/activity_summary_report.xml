<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- ── TOOLBAR ── -->
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="60dp"
        android:background="#2E7D32" android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp" android:paddingEnd="16dp" android:elevation="6dp">

        <ImageButton android:id="@+id/btnBack"
            android:layout_width="44dp" android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/outline_arrow_back_24"
            android:tint="#FFFFFF" android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:paddingStart="4dp"
            android:text="Inquiry Summary"
            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" />

        <TextView android:id="@+id/tvTotalBadge"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold"
            android:paddingHorizontal="10dp" android:paddingVertical="4dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ── SCROLL ── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp" android:paddingTop="14dp" android:paddingBottom="24dp">

            <!-- ── FILTER CARD ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="12dp" app:cardElevation="3dp" app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
                        android:background="#2E7D32" android:gravity="center_vertical"
                        android:paddingHorizontal="14dp" android:orientation="horizontal">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/outline_filter_alt_24" android:tint="#FFFFFF" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="8dp" android:text="Filter by Period"
                            android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="12dp" android:gravity="center_horizontal">
                        <TextView android:id="@+id/chipAllTime"
                            android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                            android:layout_marginEnd="6dp" android:gravity="center"
                            android:text="All Time" android:textSize="12sp" android:textStyle="bold"
                            android:background="@drawable/bg_chip_selected" android:textColor="#FFFFFF" />
                        <TextView android:id="@+id/chipToday"
                            android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                            android:layout_marginEnd="6dp" android:gravity="center"
                            android:text="Today" android:textSize="12sp" android:textStyle="bold"
                            android:background="@drawable/bg_chip_unselected" android:textColor="#2E7D32" />
                        <TextView android:id="@+id/chipLast7"
                            android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                            android:layout_marginEnd="6dp" android:gravity="center"
                            android:text="7 Days" android:textSize="12sp" android:textStyle="bold"
                            android:background="@drawable/bg_chip_unselected" android:textColor="#2E7D32" />
                        <TextView android:id="@+id/chipLast30"
                            android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                            android:gravity="center"
                            android:text="30 Days" android:textSize="12sp" android:textStyle="bold"
                            android:background="@drawable/bg_chip_unselected" android:textColor="#2E7D32" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── STATS OVERVIEW CARD ── -->
            <androidx.cardview.widget.CardView android:id="@+id/cardStats"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="12dp" app:cardElevation="3dp" app:cardBackgroundColor="#FFFFFF"
                android:visibility="gone">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="14dp">
                    <!-- Total -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                        android:background="@drawable/bg_stat_blue" android:paddingVertical="12dp"
                        android:layout_marginEnd="6dp">
                        <TextView android:id="@+id/tvTotalCount" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0"
                            android:textColor="#1565C0" android:textSize="22sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Total" android:textColor="#1565C0" android:textSize="11sp" />
                    </LinearLayout>
                    <!-- Active -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                        android:background="@drawable/bg_stat_orange" android:paddingVertical="12dp"
                        android:layout_marginEnd="6dp">
                        <TextView android:id="@+id/tvActiveCount" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0"
                            android:textColor="#E65100" android:textSize="22sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Active" android:textColor="#E65100" android:textSize="11sp" />
                    </LinearLayout>
                    <!-- Converted -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                        android:background="@drawable/bg_stat_green" android:paddingVertical="12dp"
                        android:layout_marginEnd="6dp">
                        <TextView android:id="@+id/tvConvertedCount" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0"
                            android:textColor="#2E7D32" android:textSize="22sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Converted" android:textColor="#2E7D32" android:textSize="11sp" />
                    </LinearLayout>
                    <!-- Cancelled -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                        android:background="@drawable/bg_stat_red" android:paddingVertical="12dp">
                        <TextView android:id="@+id/tvCancelledCount" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0"
                            android:textColor="#C62828" android:textSize="22sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Cancelled" android:textColor="#C62828" android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── TABLE CARD ── -->
            <androidx.cardview.widget.CardView android:id="@+id/cardTable"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="12dp" app:cardElevation="3dp" app:cardBackgroundColor="#FFFFFF"
                android:visibility="gone">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
                        android:background="#2E7D32" android:gravity="center_vertical"
                        android:paddingHorizontal="14dp" android:orientation="horizontal">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/baseline_article_24" android:tint="#FFFFFF" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginStart="8dp"
                            android:text="Course-wise Summary"
                            android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tvCourseCount"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:background="#FFFFFF" android:textColor="#2E7D32"
                            android:textSize="11sp" android:textStyle="bold"
                            android:paddingHorizontal="8dp" android:paddingVertical="2dp" />
                    </LinearLayout>
                    <!-- Table Header -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="40dp"
                        android:background="#E8F5E9" android:gravity="center_vertical"
                        android:orientation="horizontal" android:paddingHorizontal="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2.2" android:text="Course"
                            android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:gravity="center" android:text="Total"
                            android:textColor="#1565C0" android:textSize="11sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:gravity="center" android:text="Active"
                            android:textColor="#E65100" android:textSize="11sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:gravity="center" android:text="Conv."
                            android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:gravity="center" android:text="Cancel"
                            android:textColor="#C62828" android:textSize="11sp" android:textStyle="bold" />
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#CCCCCC" />
                    <LinearLayout android:id="@+id/llTableRows"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ PIE CHART CARD ══ (replaced bar chart) -->
            <androidx.cardview.widget.CardView android:id="@+id/cardChart"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="12dp" app:cardElevation="3dp" app:cardBackgroundColor="#FFFFFF"
                android:visibility="gone">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

                    <!-- Card header -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
                        android:background="#2E7D32" android:gravity="center_vertical"
                        android:paddingHorizontal="14dp" android:orientation="horizontal">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/baseline_bar_chart_24" android:tint="#FFFFFF" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="8dp" android:text="Inquiries by Course"
                            android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Pie chart — self-sizing, includes legend inside -->
                    <com.example.androidproject.InquiryPieChartView
                        android:id="@+id/pieChartView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="12dp"
                        android:paddingBottom="16dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── LOADER ── -->
    <FrameLayout android:id="@+id/loaderLayout"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#80000000" android:visibility="gone">
        <ProgressBar android:layout_width="56dp" android:layout_height="56dp"
            android:layout_gravity="center" />
    </FrameLayout>

</LinearLayout>