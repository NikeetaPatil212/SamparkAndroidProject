<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/rowContainer"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- SN -->
        <TextView android:id="@+id/tvSn"
            android:layout_width="50dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333"
            android:textSize="12sp" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Course Name -->
        <TextView android:id="@+id/tvCourseName"
            android:layout_width="160dp" android:layout_height="match_parent"
            android:gravity="center_vertical" android:paddingStart="8dp"
            android:textColor="#1A1A1A" android:textSize="12sp"
            android:textStyle="bold" android:ellipsize="end" android:maxLines="1" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Fees -->
        <TextView android:id="@+id/tvFees"
            android:layout_width="90dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#1565C0"
            android:textSize="12sp" android:textStyle="bold"
            android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Scheme -->
        <TextView android:id="@+id/tvScheme"
            android:layout_width="90dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#2E7D32"
            android:textSize="12sp" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Certificate -->
        <TextView android:id="@+id/tvCertificate"
            android:layout_width="90dp" android:layout_height="match_parent"
            android:gravity="center" android:textSize="12sp"
            android:textStyle="bold" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Duration -->
        <TextView android:id="@+id/tvDuration"
            android:layout_width="90dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333"
            android:textSize="12sp" android:paddingHorizontal="4dp" />

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

</LinearLayout>