<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F7FA"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══ SLIM GREEN HEADER ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_header_midnight"
                android:paddingTop="8dp"
                android:paddingBottom="38dp">

                <!-- Greeting -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="18dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👋 Good Morning"
                        android:textColor="#FFFFFF"
                        android:textSize="19sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Here's what's happening today."
                        android:textColor="#C8E6C9"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="18dp"
                    android:text="OVERVIEW"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:alpha="0.85" />
            </LinearLayout>

            <!-- ══ CONTENT — floats over header ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="-20dp"
                android:paddingBottom="24dp">

                <!-- ★ KPI CAROUSEL — 1 full card per swipe, adjacent peek ★ -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvKpiCards"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:overScrollMode="never" />

                <!-- Dots indicator -->
                <LinearLayout
                    android:id="@+id/dotsIndicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="4dp" />

                <!-- Swipe hint -->
                <TextView
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="← swipe to see all →"
                    android:textColor="#BDBDBD"
                    android:textSize="10sp"
                    android:layout_marginBottom="20dp" />

                <!-- ANALYTICS label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ANALYTICS"
                    android:textColor="#757575"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="6dp" />

                <!-- Fee Summary Donut -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="14dp"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💰"
                                android:textSize="16sp"
                                android:layout_marginEnd="8dp" />
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Fee Summary"
                                android:textColor="#1A1A1A"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                        <com.example.androidproject.model.dashboard.FeeDonutChartView
                            android:id="@+id/feeDonutChartView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Inquiries Trend -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="14dp"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📊"
                                android:textSize="16sp"
                                android:layout_marginEnd="8dp" />
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Inquiries Trend"
                                android:textColor="#1A1A1A"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Monthly"
                                android:textColor="#9E9E9E"
                                android:textSize="11sp" />
                        </LinearLayout>
                        <com.example.androidproject.model.dashboard.InquiryBarTrendView
                            android:id="@+id/inquiryBarTrendView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="10dp">
                            <View
                                android:layout_width="10dp" android:layout_height="10dp"
                                android:background="#1565C0" android:layout_marginEnd="6dp" />
                            <TextView
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Inquiries per month"
                                android:textColor="#757575" android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Admissions Trend -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="14dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🎓"
                                android:textSize="16sp"
                                android:layout_marginEnd="8dp" />
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Admissions Trend"
                                android:textColor="#1A1A1A"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Monthly"
                                android:textColor="#9E9E9E"
                                android:textSize="11sp" />
                        </LinearLayout>
                        <com.example.androidproject.model.dashboard.AdmissionLineTrendView
                            android:id="@+id/admissionLineTrendView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="10dp">
                            <View
                                android:layout_width="10dp" android:layout_height="10dp"
                                android:background="#2E7D32" android:layout_marginEnd="6dp" />
                            <TextView
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Admissions per month"
                                android:textColor="#757575" android:textSize="11sp" />
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>



                <!-- RECENT ACTIVITY label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="RECENT ACTIVITY"
                    android:textColor="#757575"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="6dp" />

                <!-- Recent Inquiries (collapsible) -->
                <include
                    android:id="@+id/cardRecentInquiries"
                    layout="@layout/item_collapsible_card" />

                <!-- Recent Admissions (collapsible) -->
                <include
                    android:id="@+id/cardRecentAdmissions"
                    layout="@layout/item_collapsible_card" />

                <!-- Recent Fees Collected (collapsible) -->
                <include
                    android:id="@+id/cardRecentFees"
                    layout="@layout/item_collapsible_card" />




            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Loader -->
    <FrameLayout
        android:id="@+id/loaderLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone">
        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center" />
    </FrameLayout>

</FrameLayout>