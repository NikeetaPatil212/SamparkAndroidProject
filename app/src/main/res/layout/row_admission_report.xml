<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/rowContainer"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView android:id="@+id/tvNo"
            android:layout_width="50dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333" android:textSize="11sp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

       <!-- <CheckBox android:id="@+id/cbSelect"
            android:layout_width="60dp" android:layout_height="match_parent"
            android:gravity="center" android:buttonTint="#2E7D32" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />
-->
        <TextView android:id="@+id/tvAdmDate"
            android:layout_width="90dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333" android:textSize="11sp"
            android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <TextView android:id="@+id/tvAdmId"
            android:layout_width="60dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333" android:textSize="11sp"
            android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <TextView android:id="@+id/tvStudentName"
            android:layout_width="150dp" android:layout_height="match_parent"
            android:gravity="center_vertical" android:paddingStart="8dp"
            android:textColor="#1A1A1A" android:textSize="12sp" android:textStyle="bold"
            android:ellipsize="end" android:maxLines="1" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <TextView android:id="@+id/tvMobile"
            android:layout_width="110dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333" android:textSize="11sp"
            android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <TextView android:id="@+id/tvLocation"
            android:layout_width="90dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333" android:textSize="11sp"
            android:ellipsize="end" android:maxLines="1" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <TextView android:id="@+id/tvCourse"
            android:layout_width="90dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333" android:textSize="11sp"
            android:ellipsize="end" android:maxLines="1" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <TextView android:id="@+id/tvBatch"
            android:layout_width="90dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333" android:textSize="11sp"
            android:ellipsize="end" android:maxLines="1" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <TextView android:id="@+id/tvBatchTime"
            android:layout_width="90dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333" android:textSize="11sp"
            android:ellipsize="end" android:maxLines="1" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <TextView android:id="@+id/tvFees"
            android:layout_width="70dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#1565C0" android:textSize="11sp"
            android:textStyle="bold" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <TextView android:id="@+id/tvPaid"
            android:layout_width="70dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#2E7D32" android:textSize="11sp"
            android:textStyle="bold" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <TextView android:id="@+id/tvOutstanding"
            android:layout_width="80dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#C62828" android:textSize="11sp"
            android:textStyle="bold" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

</LinearLayout>