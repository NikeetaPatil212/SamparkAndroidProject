<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/white">

    <!-- ── HEADER ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#2E7D32"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Student Actions"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ── STUDENT CARD ── -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Student Avatar -->
            <ImageView
                android:id="@+id/ivStudent"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_person_foreground"
                android:background="@drawable/bg_avtar_circle" />

            <!-- Student Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Student Name"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="2dp" />

                <!-- Mobile row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="2dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/baseline_call_24"
                        android:tint="#2E7D32"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:id="@+id/tvMobile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mobile"
                        android:textSize="13sp"
                        android:textColor="#444444" />
                </LinearLayout>

                <!-- Alt Mobile row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="2dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/baseline_add_ic_call_24"
                        android:tint="#888888"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:id="@+id/tvAltMobile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alternate No"
                        android:textSize="13sp"
                        android:textColor="#888888" />
                </LinearLayout>

                <!-- Address row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone"

                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/baseline_add_ic_call_24"
                        android:tint="#E53935"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:id="@+id/tvAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Address"
                        android:textSize="13sp"
                        android:textColor="#888888"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── DIVIDER + SELECT ACTION ── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select Action"
        android:textStyle="bold"
        android:textSize="13sp"
        android:textColor="#888888"
        android:paddingBottom="8dp"
        android:letterSpacing="0.05" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="6dp" />

    <!-- ── ACTION ITEMS (inline, no style dependency) ── -->

    <!-- View Details -->
    <LinearLayout
        android:id="@+id/tvViewDetails"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="28dp"
            android:layout_height="wrap_content"
            android:text="👁"
            android:textSize="18sp"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="View Details"
            android:textSize="14sp"
            android:textColor="#1A1A1A"
            android:paddingStart="8dp" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/outline_arrow_back_24"
            android:rotation="180"
            android:tint="#CCCCCC" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" />

    <!-- Fee Receipt -->
    <LinearLayout
        android:id="@+id/tvFeeReceipt"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="28dp"
            android:layout_height="wrap_content"
            android:text="💰"
            android:textSize="18sp"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Fee Receipt"
            android:textSize="14sp"
            android:textColor="#1A1A1A"
            android:paddingStart="8dp" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/outline_arrow_back_24"
            android:rotation="180"
            android:tint="#CCCCCC" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" />

    <!-- New Admission -->
    <LinearLayout
        android:id="@+id/tvNewAdmission"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="28dp"
            android:layout_height="wrap_content"
            android:text="🎓"
            android:textSize="18sp"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="New Admission"
            android:textSize="14sp"
            android:textColor="#1A1A1A"
            android:paddingStart="8dp" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/outline_arrow_back_24"
            android:rotation="180"
            android:tint="#CCCCCC" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" />

    <!-- Edit Profile -->
    <LinearLayout
        android:id="@+id/tvEditProfile"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="28dp"
            android:layout_height="wrap_content"
            android:text="✏️"
            android:textSize="18sp"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Edit Profile"
            android:textSize="14sp"
            android:textColor="#1A1A1A"
            android:paddingStart="8dp" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/outline_arrow_back_24"
            android:rotation="180"
            android:tint="#CCCCCC" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" />

    <!-- Delete Profile -->
    <LinearLayout
        android:id="@+id/tvDelstyeteProfile"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="28dp"
            android:layout_height="wrap_content"
            android:text="🗑"
            android:textSize="18sp"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Delete Profile"
            android:textSize="14sp"
            android:textColor="#C62828"
            android:paddingStart="8dp" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/outline_arrow_back_24"
            android:rotation="180"
            android:tint="#CCCCCC" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" />

    <!-- Go Back -->
    <LinearLayout
        android:id="@+id/tvGoBack"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="28dp"
            android:layout_height="wrap_content"
            android:text="⬅️"
            android:textSize="18sp"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Go Back"
            android:textSize="14sp"
            android:textColor="#888888"
            android:paddingStart="8dp" />
    </LinearLayout>

</LinearLayout>