<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- ── TOOLBAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#2E7D32"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:elevation="6dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/outline_arrow_back_24"
            android:tint="#FFFFFF"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="4dp"
            android:text="Inquiry Detailed Report"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStudentCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#1B5E20"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ── SCROLL CONTENT ── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="24dp">

            <!-- ══ FILTERS CARD ══ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="#2E7D32"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/baseline_article_24"
                            android:tint="#FFFFFF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Filters"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <!-- Row 1: Student Name + Contact -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="10dp">

                            <!-- Student Name -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginEnd="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Student Name"
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="4dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="46dp"
                                    android:background="@drawable/bg_edittext_outline"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:paddingHorizontal="10dp">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/ic_person_foreground"
                                        android:tint="#2E7D32"
                                        android:layout_marginEnd="6dp" />

                                    <EditText
                                        android:id="@+id/etStudentName"
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:background="@null"
                                        android:hint="Search name..."
                                        android:textColor="#1A1A1A"
                                        android:textColorHint="#AAAAAA"
                                        android:textSize="13sp"
                                        android:maxLines="1"
                                        android:singleLine="true"
                                        android:inputType="textPersonName" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- Contact No -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Contact No"
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="4dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="46dp"
                                    android:background="@drawable/bg_edittext_outline"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:paddingHorizontal="10dp">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/baseline_call_24"
                                        android:tint="#2E7D32"
                                        android:layout_marginEnd="6dp" />

                                    <EditText
                                        android:id="@+id/etContactNo"
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:background="@null"
                                        android:hint="Search contact..."
                                        android:textColor="#1A1A1A"
                                        android:textColorHint="#AAAAAA"
                                        android:textSize="13sp"
                                        android:maxLines="1"
                                        android:singleLine="true"
                                        android:inputType="phone" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Row 2: Course + Location -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="10dp">

                            <!-- Course -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginEnd="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Course"
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="4dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="46dp"
                                    android:background="@drawable/bg_edittext_outline"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:paddingStart="10dp"
                                    android:paddingEnd="4dp">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/outline_book_2_24"
                                        android:tint="#2E7D32"
                                        android:layout_marginEnd="6dp" />

                                    <Spinner
                                        android:id="@+id/spCourse"
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:background="@null"
                                        android:spinnerMode="dropdown" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- Location -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Location"
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="4dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="46dp"
                                    android:background="@drawable/bg_edittext_outline"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:paddingHorizontal="10dp">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/baseline_content_paste_search_24"
                                        android:tint="#2E7D32"
                                        android:layout_marginEnd="6dp" />

                                    <EditText
                                        android:id="@+id/etLocation"
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:background="@null"
                                        android:hint="Search location..."
                                        android:textColor="#1A1A1A"
                                        android:textColorHint="#AAAAAA"
                                        android:textSize="13sp"
                                        android:maxLines="1"
                                        android:singleLine="true"
                                        android:inputType="text" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Row 3: Status checkboxes — 2x2 grid -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Inquiry Status"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />

                        <!-- Checkbox Row 1: All + Active -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="2dp">

                            <CheckBox
                                android:id="@+id/cbAll"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="All"
                                android:textSize="12sp"
                                android:checked="true"
                                android:buttonTint="#2E7D32" />

                            <CheckBox
                                android:id="@+id/cbActive"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Active"
                                android:textSize="12sp"
                                android:buttonTint="#2E7D32" />
                        </LinearLayout>

                        <!-- Checkbox Row 2: Converted + Cancelled -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <CheckBox
                                android:id="@+id/cbConverted"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Converted"
                                android:textSize="12sp"
                                android:buttonTint="#2E7D32" />

                            <CheckBox
                                android:id="@+id/cbCancelled"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Cancelled"
                                android:textSize="12sp"
                                android:buttonTint="#2E7D32" />
                        </LinearLayout>

                        <!-- Buttons Row: Reset + View Students -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnReset"
                                android:layout_width="0dp"
                                android:layout_height="46dp"
                                android:layout_weight="1"
                                android:backgroundTint="#757575"
                                android:text="Reset"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textAllCaps="false"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:layout_marginEnd="8dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnViewStudents"
                                android:layout_width="0dp"
                                android:layout_height="46dp"
                                android:layout_weight="2"
                                android:backgroundTint="#2E7D32"
                                android:text="View Students"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textAllCaps="false"
                                android:insetTop="0dp"
                                android:insetBottom="0dp" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ STUDENT LIST CARD ══ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardStudentList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="#2E7D32"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_person_foreground"
                            android:tint="#FFFFFF" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="Inquiry List"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="#FFFFFF"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp" />
                    </LinearLayout>

                    <!-- Horizontal scrollable table -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:minWidth="1400dp">

                            <!-- Header Row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:background="#E8F5E9"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView android:layout_width="50dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="No."
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="90dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text=""
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="90dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Inq Date"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="150dp" android:layout_height="match_parent"
                                    android:gravity="center_vertical" android:paddingStart="8dp"
                                    android:text="Student Name"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="110dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Mobile"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="110dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Alternate No"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="80dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Location"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="100dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Courses"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="90dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Reminder"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="90dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Status"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="100dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Feedback"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="80dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="School"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="90dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Reference"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="60dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Select"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />

                            </LinearLayout>

                            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#CCCCCC" />

                            <!-- Data rows -->
                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rvInquiries"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:nestedScrollingEnabled="false" />

                        </LinearLayout>
                    </HorizontalScrollView>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ SEND BUTTONS ROW ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSendWhatsappMessage"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:backgroundTint="#2E7D32"
                    android:text="📱 WhatsApp"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSendSMSMessage"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:backgroundTint="#2E7D32"
                    android:text="✉️ Send SMS"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── LOADER ── -->
    <FrameLayout
        android:id="@+id/loaderLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center" />
    </FrameLayout>

</LinearLayout>