            </androidx.cardview.widget.CardView>-->


            <!-- ── Student List Card ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardStudentList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <!-- Header row: title + select all -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Student List"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#333333" />

                        <CheckBox
                            android:id="@+id/cbSelectAll"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select All"
                            android:textSize="12sp"
                            android:textColor="#333333"
                            android:buttonTint="#2E7D32" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE" />

                    <!-- ProgressBar -->
                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:visibility="gone" />

                    <!-- Empty -->
                    <TextView
                        android:id="@+id/tvEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No students found"
                        android:gravity="center"
                        android:textSize="14sp"
                        android:textColor="#AAAAAA"
                        android:padding="20dp"
                        android:visibility="gone" />

                    <!-- Horizontal scroll wraps BOTH header + list -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- Table column header -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="#E8F5E9"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp">

                                <TextView
                                    android:layout_width="36dp"
                                    android:layout_height="wrap_content"
                                    android:text="#"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#2E7D32"
                                    android:gravity="center" />

                                <TextView
                                    android:layout_width="36dp"
                                    android:layout_height="wrap_content"
                                    android:text=""
                                    android:layout_marginEnd="8dp" />

                                <TextView
                                    android:layout_width="130dp"
                                    android:layout_height="wrap_content"
                                    android:text="Student Name"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#2E7D32" />

                                <TextView
                                    android:layout_width="100dp"
                                    android:layout_height="wrap_content"
                                    android:text="Mobile"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#2E7D32"
                                    android:paddingStart="6dp" />

                                <TextView
                                    android:layout_width="70dp"
                                    android:layout_height="wrap_content"
                                    android:text="Course"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#2E7D32"
                                    android:paddingStart="6dp" />

                                <TextView
                                    android:layout_width="80dp"
                                    android:layout_height="wrap_content"
                                    android:text="Batch"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#2E7D32"
                                    android:paddingStart="6dp" />

                                <TextView
                                    android:layout_width="80dp"
                                    android:layout_height="wrap_content"
                                    android:text="Timing"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#2E7D32"
                                    android:paddingStart="6dp" />

                                <TextView
                                    android:layout_width="50dp"
                                    android:layout_height="wrap_content"
                                    android:text="Select"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#2E7D32"
                                    android:paddingStart="4dp" />

                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#CCCCCC" />

                            <!-- RecyclerView -->
                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rvStudents"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:nestedScrollingEnabled="false" />

                        </LinearLayout>

                    </HorizontalScrollView>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── Send Message button ── -->
            <!-- ── 3 Send Buttons ── -->
            <LinearLayout
                android:id="@+id/layoutSendButtons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:visibility="gone">

                <!-- Row 1: WhatsApp + SMS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Send WhatsApp -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSendWhatsApp"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="📲 WhatsApp"
                        android:textSize="12sp"
                        app:backgroundTint="#25D366"
                        app:cornerRadius="10dp" />

                    <!-- Send SMS -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSendSMS"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="💬 Send SMS"
                        android:textSize="12sp"
                        app:backgroundTint="#1565C0"
                        app:cornerRadius="10dp" />

                </LinearLayout>

                <!-- Row 2: WhatsApp + SMS together -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSendBoth"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:text="📲 WhatsApp + 💬 SMS"
                    android:textSize="13sp"
                    app:backgroundTint="#2E7D32"
                    app:cornerRadius="10dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>