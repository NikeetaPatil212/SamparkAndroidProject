<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rowRoot"
    android:layout_width="wrap_content"
    android:layout_height="48dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:background="?attr/selectableItemBackground">

    <!-- Divider line between rows -->
    <!-- Course Name — 130dp (matches header) -->
    <TextView
        android:id="@+id/tvCourseName"
        android:layout_width="130dp"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:text="MS-CIT"
        android:textColor="#1565C0"
        android:textSize="12sp"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#EEEEEE"/>

    <!-- Course ID — 80dp (matches header) -->
    <TextView
        android:id="@+id/tvCourseId"
        android:layout_width="80dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="101"
        android:textColor="#2E7D32"
        android:textSize="12sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#EEEEEE"/>

    <!-- Batch Name — 120dp (matches header) -->
    <TextView
        android:id="@+id/tvBatchName"
        android:layout_width="120dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="Morning"
        android:textColor="#1A1A1A"
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#EEEEEE"/>

    <!-- Total Fee — 90dp (matches header) -->
    <TextView
        android:id="@+id/tvTotalFee"
        android:layout_width="90dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="₹5000"
        android:textColor="#1A1A1A"
        android:textSize="12sp"
        android:maxLines="1" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#EEEEEE"/>

    <!-- Paid Fee — 90dp (matches header) -->
    <TextView
        android:id="@+id/tvPaidFee"
        android:layout_width="90dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="₹2000"
        android:textColor="#2E7D32"
        android:textSize="12sp"
        android:textStyle="bold"
        android:maxLines="1" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#EEEEEE"/>

    <!-- Remaining Fee — 110dp pill (matches header "Remaining" 110dp) -->
    <LinearLayout
        android:layout_width="110dp"
        android:layout_height="match_parent"
        android:gravity="center">

        <TextView
            android:id="@+id/tvRemainingFee"
            android:layout_width="90dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="₹3000"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/bg_status_pill"
            android:maxLines="1" />
    </LinearLayout>

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#EEEEEE"/>

    <!-- Batch ID — 80dp (matches header) -->
    <TextView
        android:id="@+id/tvBatchId"
        android:layout_width="80dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="201"
        android:textColor="#888888"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end" />

</LinearLayout>