<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/rowContainer"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Adm ID -->
        <TextView android:id="@+id/tvAdmId"
            android:layout_width="60dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333"
            android:textSize="12sp" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Student ID -->
        <TextView android:id="@+id/tvStudentId"
            android:layout_width="60dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333"
            android:textSize="12sp" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Adm Date -->
        <TextView android:id="@+id/tvAdmDate"
            android:layout_width="90dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333"
            android:textSize="11sp" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Student Name -->
        <TextView android:id="@+id/tvStudentName"
            android:layout_width="150dp" android:layout_height="match_parent"
            android:gravity="center_vertical" android:paddingStart="8dp"
            android:textColor="#1A1A1A" android:textSize="12sp"
            android:textStyle="bold" android:ellipsize="end" android:maxLines="1" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Mobile -->
        <TextView android:id="@+id/tvMobile"
            android:layout_width="110dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333"
            android:textSize="11sp" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Location -->
        <TextView android:id="@+id/tvLocation"
            android:layout_width="80dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333"
            android:textSize="11sp" android:ellipsize="end" android:maxLines="1"
            android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Course -->
        <TextView android:id="@+id/tvCourse"
            android:layout_width="80dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333"
            android:textSize="11sp" android:ellipsize="end" android:maxLines="1"
            android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Scheme -->
        <TextView android:id="@+id/tvScheme"
            android:layout_width="70dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333"
            android:textSize="11sp" android:ellipsize="end" android:maxLines="1"
            android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Batch -->
        <TextView android:id="@+id/tvBatch"
            android:layout_width="100dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333"
            android:textSize="11sp" android:ellipsize="end" android:maxLines="1"
            android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Fee -->
        <TextView android:id="@+id/tvFee"
            android:layout_width="70dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333"
            android:textSize="11sp" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Paid -->
        <TextView android:id="@+id/tvPaid"
            android:layout_width="70dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#2E7D32"
            android:textSize="11sp" android:textStyle="bold"
            android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Outstanding -->
        <TextView android:id="@+id/tvOutstanding"
            android:layout_width="80dp" android:layout_height="match_parent"
            android:gravity="center" android:textSize="11sp"
            android:textStyle="bold" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Fee Status -->
        <TextView android:id="@+id/tvStatus"
            android:layout_width="80dp" android:layout_height="match_parent"
            android:gravity="center" android:textSize="11sp"
            android:textStyle="bold" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Certificate -->
        <TextView android:id="@+id/tvCertificate"
            android:layout_width="80dp" android:layout_height="match_parent"
            android:gravity="center" android:textSize="11sp"
            android:textStyle="bold" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Certificate ID -->
        <TextView android:id="@+id/tvCertificateId"
            android:layout_width="90dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333"
            android:textSize="11sp" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Issuer -->
        <TextView android:id="@+id/tvIssuer"
            android:layout_width="90dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333"
            android:textSize="11sp" android:ellipsize="end" android:maxLines="1"
            android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Issuer Contact -->
        <TextView android:id="@+id/tvIssuerContact"
            android:layout_width="110dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333"
            android:textSize="11sp" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Certificate No -->
        <TextView android:id="@+id/tvCertificateNo"
            android:layout_width="100dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333"
            android:textSize="11sp" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Issue Date -->
        <TextView android:id="@+id/tvIssueDate"
            android:layout_width="90dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333"
            android:textSize="11sp" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Result -->
        <TextView android:id="@+id/tvResult"
            android:layout_width="70dp" android:layout_height="match_parent"
            android:gravity="center" android:textSize="11sp"
            android:textStyle="bold" android:paddingHorizontal="4dp" />
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Percentage -->
        <TextView android:id="@+id/tvPercentage"
            android:layout_width="80dp" android:layout_height="match_parent"
            android:gravity="center" android:textColor="#333333"
            android:textSize="11sp" android:paddingHorizontal="4dp" />

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

</LinearLayout>