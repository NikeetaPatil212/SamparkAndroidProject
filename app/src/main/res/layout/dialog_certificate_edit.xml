<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="#2E7D32"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Certificate Details"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnCloseDialog"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/baseline_close_24"
            android:tint="#FFFFFF" />
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Student Info -->
            <TextView
                android:id="@+id/tvDialogStudentName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvDialogAdmInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#777777"
                android:layout_marginBottom="10dp" />

            <!-- Row 1: Cert ID + Issuer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="6dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Certificate No *" android:textColor="#2E7D32"
                        android:textSize="10sp" android:textStyle="bold"
                        android:layout_marginBottom="3dp" />

                    <EditText android:id="@+id/etCertificateId"
                        android:layout_width="match_parent" android:layout_height="40dp"
                        android:background="@drawable/bg_edittext_outline"
                        android:paddingHorizontal="10dp"
                        android:hint="Certificate No"
                        android:textSize="12sp" android:textColor="#1A1A1A" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Issuer *" android:textColor="#2E7D32"
                        android:textSize="10sp" android:textStyle="bold"
                        android:layout_marginBottom="3dp" />

                    <EditText android:id="@+id/etIssuer"
                        android:layout_width="match_parent" android:layout_height="40dp"
                        android:background="@drawable/bg_edittext_outline"
                        android:paddingHorizontal="10dp"
                        android:hint="Issuer name"
                        android:textSize="12sp" android:textColor="#1A1A1A" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2: Issuer Contact + Issue Date -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="6dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Issuer Contact" android:textColor="#2E7D32"
                        android:textSize="10sp" android:textStyle="bold"
                        android:layout_marginBottom="3dp" />

                    <EditText android:id="@+id/etIssuerContact"
                        android:layout_width="match_parent" android:layout_height="40dp"
                        android:background="@drawable/bg_edittext_outline"
                        android:paddingHorizontal="10dp"
                        android:hint="Contact number"
                        android:inputType="phone"
                        android:textSize="12sp" android:textColor="#1A1A1A" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Issue Date *" android:textColor="#2E7D32"
                        android:textSize="10sp" android:textStyle="bold"
                        android:layout_marginBottom="3dp" />

                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="40dp"
                        android:background="@drawable/bg_edittext_outline"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="10dp">

                        <EditText android:id="@+id/etIssueDate"
                            android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:background="@null"
                            android:hint="Select date"
                            android:focusable="false" android:clickable="true"
                            android:cursorVisible="false" android:inputType="none"
                            android:textSize="12sp" android:textColor="#1A1A1A" />

                        <ImageView android:layout_width="16dp" android:layout_height="16dp"
                            android:src="@drawable/baseline_calendar_today_24"
                            android:tint="#2E7D32" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Row 3: Result + Percentage -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="6dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Result *" android:textColor="#2E7D32"
                        android:textSize="10sp" android:textStyle="bold"
                        android:layout_marginBottom="3dp" />

                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="40dp"
                        android:background="@drawable/bg_edittext_outline"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="10dp" android:paddingEnd="4dp">

                        <AutoCompleteTextView android:id="@+id/etResult"
                            android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:background="@null"
                            android:hint="Select"
                            android:inputType="none" android:cursorVisible="false"
                            android:textSize="12sp" android:textColor="#1A1A1A" />

                        <ImageView android:layout_width="16dp" android:layout_height="16dp"
                            android:src="@drawable/outline_arrow_drop_down_24"
                            android:tint="#2E7D32" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Percentage" android:textColor="#2E7D32"
                        android:textSize="10sp" android:textStyle="bold"
                        android:layout_marginBottom="3dp" />

                    <EditText android:id="@+id/etPercentage"
                        android:layout_width="match_parent" android:layout_height="40dp"
                        android:background="@drawable/bg_edittext_outline"
                        android:paddingHorizontal="10dp"
                        android:hint="e.g. 85"
                        android:inputType="numberDecimal"
                        android:textSize="12sp" android:textColor="#1A1A1A" />
                </LinearLayout>
            </LinearLayout>

            <!-- Issuer Image — compact row -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Issuer Image" android:textColor="#2E7D32"
                android:textSize="10sp" android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <ImageView
                    android:id="@+id/ivIssuerImg"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:scaleType="centerCrop"
                    android:background="#F0F0F0"
                    android:src="@drawable/ic_person_foreground"
                    android:layout_marginEnd="10dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCaptureImage"
                        android:layout_width="match_parent"
                        android:layout_height="34dp"
                        android:backgroundTint="#2E7D32"
                        android:text="📷 Capture"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textAllCaps="false"
                        android:insetTop="0dp" android:insetBottom="0dp"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPickImage"
                        android:layout_width="match_parent"
                        android:layout_height="34dp"
                        android:backgroundTint="#1565C0"
                        android:text="🖼 Gallery"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textAllCaps="false"
                        android:insetTop="0dp" android:insetBottom="0dp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvImageStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#777777"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <!-- Save Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveCertificate"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:backgroundTint="#2E7D32"
                android:text="Save Details"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:insetTop="0dp" android:insetBottom="0dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Loader -->
    <FrameLayout
        android:id="@+id/dialogLoader"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:gravity="center"
        android:visibility="gone">
        <ProgressBar
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center" />
    </FrameLayout>

</LinearLayout>