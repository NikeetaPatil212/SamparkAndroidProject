<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- ── TOOLBAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#2E7D32"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:elevation="6dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/outline_arrow_back_24"
            android:tint="#FFFFFF"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="4dp"
            android:text="Certificate Hand Over"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStudentCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#1B5E20"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ── SCROLL CONTENT ── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="24dp">

            <!-- ══ CARD 1: FILTERS ══ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="#2E7D32"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/baseline_article_24"
                            android:tint="#FFFFFF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Filters"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Card Body -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <!-- ── COURSE SPINNER ── -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Course *"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="12dp"
                            android:paddingEnd="4dp"
                            android:layout_marginBottom="14dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/outline_book_2_24"
                                android:tint="#2E7D32"
                                android:layout_marginEnd="8dp" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="20dp"
                                android:background="#DDDDDD"
                                android:layout_marginEnd="8dp" />

                            <Spinner
                                android:id="@+id/spCourse"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@null"
                                android:spinnerMode="dropdown" />

                        </LinearLayout>

                        <!-- ── BATCH SPINNER (optional) ── -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Batch (Optional)"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="12dp"
                            android:paddingEnd="4dp"
                            android:layout_marginBottom="14dp">

                            <ImageView
                                android:id="@+id/ivBatchIcon"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/outline_book_2_24"
                                android:tint="#AAAAAA"
                                android:layout_marginEnd="8dp" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="20dp"
                                android:background="#DDDDDD"
                                android:layout_marginEnd="8dp" />

                            <Spinner
                                android:id="@+id/spBatch"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@null"
                                android:enabled="false"
                                android:spinnerMode="dropdown" />

                        </LinearLayout>

                        <!-- ── STUDENT NAME SEARCH ── -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Search Student Name"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:layout_marginBottom="14dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_person_foreground"
                                android:tint="#2E7D32"
                                android:layout_marginEnd="8dp" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="20dp"
                                android:background="#DDDDDD"
                                android:layout_marginEnd="8dp" />

                            <EditText
                                android:id="@+id/etStudentName"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@null"
                                android:hint="Enter student name..."
                                android:textColor="#1A1A1A"
                                android:textColorHint="#AAAAAA"
                                android:textSize="14sp"
                                android:maxLines="1"
                                android:singleLine="true"
                                android:inputType="textPersonName"
                                android:imeOptions="actionSearch" />

                            <ImageView
                                android:id="@+id/ivClearSearch"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/baseline_edit_24"
                                android:tint="#AAAAAA"
                                android:visibility="gone" />

                        </LinearLayout>

                        <!-- ── VIEW STUDENTS BUTTON ── -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnViewStudents"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:backgroundTint="#2E7D32"
                            android:text="View Students"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textAllCaps="false"
                            android:enabled="false"
                            android:insetTop="0dp"
                            android:insetBottom="0dp" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ CARD 2: STUDENT LIST ══ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardStudentList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="#2E7D32"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_person_foreground"
                            android:tint="#FFFFFF" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="Student List"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="#FFFFFF"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp" />
                    </LinearLayout>

                    <!-- ── HORIZONTAL SCROLLABLE TABLE ── -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:minWidth="2000dp">

                            <!-- Table Header Row -->
                            <!-- Table Header Row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="42dp"
                                android:background="#E8F5E9"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView android:layout_width="60dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Adm ID"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold"
                                    android:paddingHorizontal="4dp" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="60dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Std ID"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold"
                                    android:paddingHorizontal="4dp" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="90dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Adm Date"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold"
                                    android:paddingHorizontal="4dp" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="150dp" android:layout_height="match_parent"
                                    android:gravity="center_vertical" android:paddingStart="8dp"
                                    android:text="Student Name"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="110dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Mobile"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="80dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Location"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold"
                                    android:paddingHorizontal="4dp" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="80dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Course"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold"
                                    android:paddingHorizontal="4dp" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="70dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Scheme"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold"
                                    android:paddingHorizontal="4dp" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="100dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Batch"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold"
                                    android:paddingHorizontal="4dp" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="70dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Fee"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold"
                                    android:paddingHorizontal="4dp" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="70dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Paid"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold"
                                    android:paddingHorizontal="4dp" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="80dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Outstanding"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold"
                                    android:paddingHorizontal="4dp" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="80dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Fee Status"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold"
                                    android:paddingHorizontal="4dp" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="80dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Certificate"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold"
                                    android:paddingHorizontal="4dp" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="90dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Cert ID"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold"
                                    android:paddingHorizontal="4dp" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="90dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Issuer"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold"
                                    android:paddingHorizontal="4dp" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="110dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Issuer Contact"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold"
                                    android:paddingHorizontal="4dp" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="100dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Cert No."
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold"
                                    android:paddingHorizontal="4dp" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="90dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Issue Date"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold"
                                    android:paddingHorizontal="4dp" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="70dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Result"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold"
                                    android:paddingHorizontal="4dp" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView android:layout_width="80dp" android:layout_height="match_parent"
                                    android:gravity="center" android:text="Percentage"
                                    android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold"
                                    android:paddingHorizontal="4dp" />

                            </LinearLayout>

                            <!-- Divider -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#CCCCCC" />

                            <!-- Student rows — inflated dynamically -->
                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rvStudents"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:nestedScrollingEnabled="false" />

                        </LinearLayout>
                    </HorizontalScrollView>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── LOADER OVERLAY ── -->
    <FrameLayout
        android:id="@+id/loaderLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center" />
    </FrameLayout>

</LinearLayout>