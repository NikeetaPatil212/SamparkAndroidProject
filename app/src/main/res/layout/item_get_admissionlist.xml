<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rowRoot"
    android:layout_width="match_parent"
    android:layout_height="50dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="8dp"
    android:background="?attr/selectableItemBackground">

    <!-- ID — 44dp -->
    <TextView
        android:id="@+id/tvAdmId"
        android:layout_width="44dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="24"
        android:textColor="#2E7D32"
        android:textSize="13sp"
        android:textStyle="bold" />

    <!-- Date — 82dp -->
    <TextView
        android:id="@+id/tvDate"
        android:layout_width="82dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="18-03-26"
        android:textColor="#666666"
        android:textSize="11sp" />

    <!-- Name — 160dp, full name no ellipsize -->
    <TextView
        android:id="@+id/tvName"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:gravity="start"
        android:text="Aarvi Pawar"
        android:textColor="#1A1A1A"
        android:textSize="12sp"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="none" />

    <!-- Course — 80dp -->
    <TextView
        android:id="@+id/tvCourse"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="MS-CIT"
        android:textColor="#1565C0"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Status — 80dp, pill shaped -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="72dp"
        android:layout_height="28dp"
        android:gravity="center"
        android:text="Pending"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:background="@drawable/bg_status_pill" />

    <!-- Scheme — 80dp -->
    <TextView
        android:id="@+id/tvScheme"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Regular"
        android:textColor="#555555"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end" />

</LinearLayout>