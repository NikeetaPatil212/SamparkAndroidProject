<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- ── TOOLBAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#2E7D32"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:elevation="6dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/outline_arrow_back_24"
            android:tint="#FFFFFF"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="4dp"
            android:text="Edit Transactions"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ── SCROLL CONTENT ── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="24dp">

            <!-- ══ RESULTS SECTION ══ -->
            <LinearLayout
                android:id="@+id/layoutResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- ── COURSE & FEE DETAILS CARD ── -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="#2E7D32"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="14dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/outline_book_2_24"
                                android:tint="#FFFFFF" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="Course &amp; Fee Details"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <!-- Course + Batch -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="12dp">

                                <ImageView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@drawable/outline_book_2_24"
                                    android:tint="#2E7D32"
                                    android:layout_marginEnd="10dp" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tvCourseName"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textColor="#1A1A1A"
                                        android:textSize="15sp"
                                        android:textStyle="bold" />

                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal"
                                        android:gravity="center_vertical"
                                        android:layout_marginTop="2dp">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="Batch : "
                                            android:textColor="#757575"
                                            android:textSize="12sp" />

                                        <TextView
                                            android:id="@+id/tvBatchName"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:textColor="#2E7D32"
                                            android:textSize="12sp"
                                            android:textStyle="bold" />
                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>

                            <View android:layout_width="match_parent" android:layout_height="1dp"
                                android:background="#E0E0E0" android:layout_marginBottom="10dp"/>

                            <!-- Fee -->
                            <LinearLayout android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="6dp">

                                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:text="Fee"
                                    android:textColor="#555555" android:textSize="13sp" />

                                <TextView android:id="@+id/tvTotalFees"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textColor="#1A1A1A" android:textSize="13sp" android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Paid Fee -->
                            <LinearLayout android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="6dp">

                                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:text="Paid Fee"
                                    android:textColor="#555555" android:textSize="13sp" />

                                <TextView android:id="@+id/tvPaidFees"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textColor="#2E7D32" android:textSize="13sp" android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Remaining Fee -->
                            <LinearLayout android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:text="Remaining Fee"
                                    android:textColor="#555555" android:textSize="13sp" />

                                <TextView android:id="@+id/tvRemainingFees"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textSize="13sp" android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── STUDENT DETAILS CARD ── -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="#2E7D32"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="14dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_person_foreground"
                                android:tint="#FFFFFF" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="Student Details"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <!-- Student ID + Admission ID -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="8dp">

                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Student ID : " android:textColor="#757575" android:textSize="12sp" />

                                <TextView android:id="@+id/tvStudentId"
                                    android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:textColor="#1A1A1A" android:textSize="12sp" android:textStyle="bold" />

                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Adm ID : " android:textColor="#757575" android:textSize="12sp" />

                                <TextView android:id="@+id/tvAdmissionId"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textColor="#1A1A1A" android:textSize="12sp" android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Student Name -->
                            <LinearLayout android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal" android:gravity="center_vertical"
                                android:layout_marginBottom="6dp">

                                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                                    android:src="@drawable/ic_person_foreground"
                                    android:tint="#2E7D32" android:layout_marginEnd="8dp" />

                                <TextView android:id="@+id/tvStudentName"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textColor="#1A1A1A" android:textSize="14sp" android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Mobile -->
                            <LinearLayout android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal" android:gravity="center_vertical">

                                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                    android:src="@drawable/baseline_call_24"
                                    android:tint="#2E7D32" android:layout_marginEnd="8dp" />

                                <TextView android:id="@+id/tvMobile"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textColor="#333333" android:textSize="13sp" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── PAYMENT HISTORY CARD ── (green theme, no orange) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- ✅ Green header — matches app theme -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="#2E7D32"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="14dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/baseline_bar_chart_24"
                                android:tint="#FFFFFF" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="Payment History"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Tap hint -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:paddingTop="6dp"
                            android:paddingBottom="4dp"
                            android:text="Tap a row to edit"
                            android:textColor="#1565C0"
                            android:textSize="11sp"
                            android:textStyle="italic" />

                        <!-- Horizontal scroll table -->
                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:scrollbars="horizontal">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:minWidth="560dp">

                                <!-- Table Header — green theme -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="40dp"
                                    android:background="#E8F5E9"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <TextView android:layout_width="100dp" android:layout_height="match_parent"
                                        android:gravity="center" android:text="Date"
                                        android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC"/>

                                    <TextView android:layout_width="70dp" android:layout_height="match_parent"
                                        android:gravity="center" android:text="UTNO"
                                        android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC"/>

                                    <TextView android:layout_width="110dp" android:layout_height="match_parent"
                                        android:gravity="center" android:text="Type"
                                        android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC"/>

                                    <TextView android:layout_width="90dp" android:layout_height="match_parent"
                                        android:gravity="center" android:text="DR"
                                        android:textColor="#C62828" android:textSize="11sp" android:textStyle="bold" />
                                    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC"/>

                                    <TextView android:layout_width="90dp" android:layout_height="match_parent"
                                        android:gravity="center" android:text="CR"
                                        android:textColor="#2E7D32" android:textSize="11sp" android:textStyle="bold" />
                                </LinearLayout>

                                <View android:layout_width="match_parent" android:layout_height="1dp"
                                    android:background="#CCCCCC"/>

                                <androidx.recyclerview.widget.RecyclerView
                                    android:id="@+id/rvTransactions"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:nestedScrollingEnabled="false" />
                            </LinearLayout>
                        </HorizontalScrollView>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── EDIT TRANSACTION CARD ── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardEditTransaction"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="#2E7D32"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="14dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/baseline_edit_24"
                                android:tint="#FFFFFF" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="Edit Transaction"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <!-- TRNO + TRDATE row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="12dp">

                                <!-- TRNO -->
                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:orientation="vertical"
                                    android:layout_marginEnd="8dp">

                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:text="TRN No" android:textColor="#2E7D32"
                                        android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>

                                    <LinearLayout android:layout_width="match_parent" android:layout_height="46dp"
                                        android:background="@drawable/bg_edittext_outline"
                                        android:gravity="center_vertical" android:paddingHorizontal="10dp">

                                        <TextView android:id="@+id/tvTrno"
                                            android:layout_width="match_parent" android:layout_height="wrap_content"
                                            android:textColor="#1A1A1A" android:textSize="13sp" android:textStyle="bold"/>
                                    </LinearLayout>
                                </LinearLayout>

                                <!-- TRDATE -->
                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:orientation="vertical">

                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:text="TR Date" android:textColor="#2E7D32"
                                        android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>

                                    <LinearLayout android:layout_width="match_parent" android:layout_height="46dp"
                                        android:background="@drawable/bg_edittext_outline"
                                        android:gravity="center_vertical" android:orientation="horizontal"
                                        android:paddingHorizontal="10dp">

                                        <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                            android:src="@drawable/baseline_calendar_today_24"
                                            android:tint="#2E7D32" android:layout_marginEnd="6dp"/>

                                        <EditText android:id="@+id/etTrDate"
                                            android:layout_width="0dp" android:layout_height="match_parent"
                                            android:layout_weight="1" android:background="@null"
                                            android:hint="DD/MM/YYYY" android:textColor="#1A1A1A"
                                            android:textColorHint="#AAAAAA" android:textSize="13sp"
                                            android:focusable="false" android:clickable="true"/>

                                        <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                            android:src="@drawable/outline_arrow_drop_down_24"
                                            android:tint="#2E7D32"/>
                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>

                            <!-- Transaction Type (read-only) -->
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Transaction Type" android:textColor="#2E7D32"
                                android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>

                            <LinearLayout android:layout_width="match_parent" android:layout_height="46dp"
                                android:background="@drawable/bg_edittext_outline"
                                android:gravity="center_vertical" android:paddingHorizontal="10dp"
                                android:layout_marginBottom="12dp">

                                <TextView android:id="@+id/tvTransactionType"
                                    android:layout_width="match_parent" android:layout_height="wrap_content"
                                    android:textColor="#1565C0" android:textSize="13sp" android:textStyle="bold"/>
                            </LinearLayout>

                            <!-- Amount -->
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Amount (₹)" android:textColor="#2E7D32"
                                android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>

                            <LinearLayout android:layout_width="match_parent" android:layout_height="46dp"
                                android:background="@drawable/bg_edittext_outline"
                                android:gravity="center_vertical" android:orientation="horizontal"
                                android:paddingHorizontal="10dp" android:layout_marginBottom="12dp">

                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="₹" android:textColor="#2E7D32"
                                    android:textSize="16sp" android:textStyle="bold"
                                    android:layout_marginEnd="8dp"/>

                                <EditText android:id="@+id/etTransactionAmt"
                                    android:layout_width="0dp" android:layout_height="match_parent"
                                    android:layout_weight="1" android:background="@null"
                                    android:hint="0" android:textColor="#1A1A1A"
                                    android:textColorHint="#AAAAAA" android:textSize="14sp"
                                    android:textStyle="bold" android:singleLine="true"
                                    android:inputType="numberDecimal"/>
                            </LinearLayout>

                            <!-- Narration / Comments -->
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Comments" android:textColor="#2E7D32"
                                android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>

                            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                                android:background="@drawable/bg_edittext_outline"
                                android:gravity="center_vertical" android:paddingHorizontal="10dp"
                                android:layout_marginBottom="16dp">

                                <EditText android:id="@+id/etNarration"
                                    android:layout_width="match_parent" android:layout_height="match_parent"
                                    android:background="@null" android:hint="Enter comments (optional)"
                                    android:textColor="#1A1A1A" android:textColorHint="#AAAAAA"
                                    android:textSize="13sp" android:inputType="textMultiLine"
                                    android:gravity="top"/>
                            </LinearLayout>

                            <!-- Update Button -->
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnUpdate"
                                android:layout_width="match_parent"
                                android:layout_height="50dp"
                                android:backgroundTint="#2E7D32"
                                android:text="✏️  Update Transaction"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textAllCaps="false"
                                android:insetTop="0dp"
                                android:insetBottom="0dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── LOADER ── -->
    <FrameLayout
        android:id="@+id/loaderLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center" />
    </FrameLayout>

</LinearLayout>