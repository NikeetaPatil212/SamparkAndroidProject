<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- ── TOOLBAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#2E7D32"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:elevation="6dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/outline_arrow_back_24"
            android:tint="#FFFFFF"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="4dp"
            android:text="Courses"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCourseCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#1B5E20"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ── SCROLL CONTENT ── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="24dp">

            <!-- ══ FORM CARD ══ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="#2E7D32"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/outline_book_2_24"
                            android:tint="#FFFFFF" />

                        <TextView
                            android:id="@+id/tvFormTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Add New Course"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <!-- Course Name -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Course Name"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="10dp"
                            android:layout_marginBottom="12dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/outline_book_2_24"
                                android:tint="#2E7D32"
                                android:layout_marginEnd="6dp" />

                            <EditText
                                android:id="@+id/etCourseName"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@null"
                                android:hint="Enter course name"
                                android:textColor="#1A1A1A"
                                android:textColorHint="#AAAAAA"
                                android:textSize="13sp"
                                android:singleLine="true"
                                android:inputType="textCapWords" />
                        </LinearLayout>

                        <!-- Row: Scheme + Certificate -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <!-- Scheme -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginEnd="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Type (Scheme)"
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="4dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="46dp"
                                    android:background="@drawable/bg_edittext_outline"
                                    android:gravity="center_vertical"
                                    android:paddingStart="10dp"
                                    android:paddingEnd="4dp">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/outline_filter_alt_24"
                                        android:tint="#2E7D32"
                                        android:layout_marginEnd="6dp" />

                                    <Spinner
                                        android:id="@+id/spScheme"
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:background="@null"
                                        android:spinnerMode="dropdown" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- Certificate -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Certificate Course"
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="4dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="46dp"
                                    android:background="@drawable/bg_edittext_outline"
                                    android:gravity="center_vertical"
                                    android:paddingStart="10dp"
                                    android:paddingEnd="4dp">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/baseline_article_24"
                                        android:tint="#2E7D32"
                                        android:layout_marginEnd="6dp" />

                                    <Spinner
                                        android:id="@+id/spCertificate"
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:background="@null"
                                        android:spinnerMode="dropdown" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Row: Fee + Duration -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">

                            <!-- Fee -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginEnd="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Fee (₹)"
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="4dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="46dp"
                                    android:background="@drawable/bg_edittext_outline"
                                    android:gravity="center_vertical"
                                    android:paddingHorizontal="10dp">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/baseline_bar_chart_24"
                                        android:tint="#2E7D32"
                                        android:layout_marginEnd="6dp" />

                                    <EditText
                                        android:id="@+id/etFees"
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:background="@null"
                                        android:hint="0"
                                        android:textColor="#1A1A1A"
                                        android:textColorHint="#AAAAAA"
                                        android:textSize="13sp"
                                        android:singleLine="true"
                                        android:inputType="numberDecimal" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- Duration -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Duration (Months)"
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="4dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="46dp"
                                    android:background="@drawable/bg_edittext_outline"
                                    android:gravity="center_vertical"
                                    android:paddingHorizontal="10dp">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/baseline_bar_chart_24"
                                        android:tint="#2E7D32"
                                        android:layout_marginEnd="6dp" />

                                    <EditText
                                        android:id="@+id/etDuration"
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:background="@null"
                                        android:hint="0"
                                        android:textColor="#1A1A1A"
                                        android:textColorHint="#AAAAAA"
                                        android:textSize="13sp"
                                        android:singleLine="true"
                                        android:inputType="number" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Action Buttons -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnCancelEdit"
                                android:layout_width="0dp"
                                android:layout_height="46dp"
                                android:layout_weight="1"
                                android:backgroundTint="#757575"
                                android:text="Cancel"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textAllCaps="false"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:layout_marginEnd="8dp"
                                android:visibility="gone" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnSave"
                                android:layout_width="0dp"
                                android:layout_height="46dp"
                                android:layout_weight="2"
                                android:backgroundTint="#2E7D32"
                                android:text="💾  Save Course"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textAllCaps="false"
                                android:insetTop="0dp"
                                android:insetBottom="0dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnUpdate"
                                android:layout_width="0dp"
                                android:layout_height="46dp"
                                android:layout_weight="2"
                                android:backgroundTint="#1565C0"
                                android:text="✏️  Update Course"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textAllCaps="false"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:visibility="gone" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ COURSE LIST CARD ══ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCourseList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="#2E7D32"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/outline_book_2_24"
                            android:tint="#FFFFFF" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="Course List"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvListCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="#FFFFFF"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp" />
                    </LinearLayout>

                    <!-- Horizontal scrollable table -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:minWidth="570dp">

                            <!-- Header Row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:background="#E8F5E9"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="50dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="No."
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView
                                    android:layout_width="160dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center_vertical"
                                    android:paddingStart="8dp"
                                    android:text="Course Name"
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView
                                    android:layout_width="90dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="Fees"
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView
                                    android:layout_width="90dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="Scheme"
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView
                                    android:layout_width="90dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="Certificate"
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />
                                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC" />

                                <TextView
                                    android:layout_width="90dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="Duration"
                                    android:textColor="#2E7D32"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#CCCCCC" />

                            <!-- Data Rows -->
                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rvCourses"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:nestedScrollingEnabled="false" />

                        </LinearLayout>
                    </HorizontalScrollView>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── LOADER ── -->
    <FrameLayout
        android:id="@+id/loaderLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center" />
    </FrameLayout>

</LinearLayout>