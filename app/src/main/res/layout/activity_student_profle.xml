<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- ── TOOLBAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#2E7D32"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:elevation="6dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/outline_arrow_back_24"
            android:tint="#FFFFFF"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="4dp"
            android:text="Student Profile"
            android:textColor="#FFFFFF"
            android:textSize="19sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ── SCROLL CONTENT ── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="24dp">

            <!-- ══ CARD 1: ADMISSION SUMMARY ══ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- ── Clickable Card Header ── -->
                    <LinearLayout
                        android:id="@+id/headerAdmissionSummary"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_card_header_selector"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/baseline_article_24"
                            android:tint="#FFFFFF" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="Admission Summary"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <!-- Expand / collapse arrow -->
                        <ImageView
                            android:id="@+id/ivArrowAdmission"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/outline_arrow_drop_down_24"
                            android:tint="#FFFFFF"
                            android:rotation="0" />
                    </LinearLayout>

                    <!-- ── Collapsible Body ── -->
                    <LinearLayout
                        android:id="@+id/bodyAdmissionSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:visibility="visible">

                        <!-- Course row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="110dp"
                                android:layout_height="wrap_content"
                                android:text="Course"
                                android:textColor="#2E7D32"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="20dp"
                                android:background="#DDDDDD"
                                android:layout_marginEnd="10dp" />

                            <TextView
                                android:id="@+id/tvCourse"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="—"
                                android:textColor="#1A1A1A"
                                android:textSize="13sp"
                                android:singleLine="true"
                                android:ellipsize="end" />
                        </LinearLayout>

                        <!-- Batch row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="110dp"
                                android:layout_height="wrap_content"
                                android:text="Batch"
                                android:textColor="#2E7D32"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="20dp"
                                android:background="#DDDDDD"
                                android:layout_marginEnd="10dp" />

                            <TextView
                                android:id="@+id/tvBatch"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="—"
                                android:textColor="#1A1A1A"
                                android:textSize="13sp"
                                android:singleLine="true"
                                android:ellipsize="end" />
                        </LinearLayout>

                        <!-- Fee row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="110dp"
                                android:layout_height="wrap_content"
                                android:text="Fee"
                                android:textColor="#2E7D32"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="20dp"
                                android:background="#DDDDDD"
                                android:layout_marginEnd="10dp" />

                            <TextView
                                android:id="@+id/tvFee"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="—"
                                android:textColor="#1A1A1A"
                                android:textSize="13sp"
                                android:singleLine="true" />
                        </LinearLayout>

                        <!-- Outstanding row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="110dp"
                                android:layout_height="wrap_content"
                                android:text="Outstanding"
                                android:textColor="#C62828"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="20dp"
                                android:background="#DDDDDD"
                                android:layout_marginEnd="10dp" />

                            <TextView
                                android:id="@+id/tvOutstanding"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="—"
                                android:textColor="#C62828"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:singleLine="true" />
                        </LinearLayout>

                        <!-- Due Date row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp">

                            <TextView
                                android:layout_width="110dp"
                                android:layout_height="wrap_content"
                                android:text="Due Date"
                                android:textColor="#888888"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="20dp"
                                android:background="#DDDDDD"
                                android:layout_marginEnd="10dp" />

                            <TextView
                                android:id="@+id/tvDueDate"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="—"
                                android:textColor="#C62828"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:singleLine="true" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ CARD 2: PERSONAL DETAILS ══ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- ── Clickable Card Header ── -->
                    <LinearLayout
                        android:id="@+id/headerPersonalDetails"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_card_header_selector"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_person_foreground"
                            android:tint="#FFFFFF" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="Personal Details"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/ivArrowPersonal"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/outline_arrow_drop_down_24"
                            android:tint="#FFFFFF"
                            android:rotation="0" />
                    </LinearLayout>

                    <!-- ── Collapsible Body ── -->
                    <LinearLayout
                        android:id="@+id/bodyPersonalDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:visibility="visible">

                        <!-- Avatar + Browse -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <ImageView
                                android:id="@+id/ivStudentPhoto"
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:src="@drawable/baseline_account_circle_24"
                                android:tint="#1565C0"
                                android:scaleType="centerCrop"
                                android:layout_marginEnd="12dp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvFullName"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textColor="#1A1A1A"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:singleLine="true"
                                    android:ellipsize="end" />

                                <TextView
                                    android:id="@+id/tvBrowseImage"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Browse Image"
                                    android:textColor="#1565C0"
                                    android:textSize="11sp"
                                    android:layout_marginTop="4dp"
                                    android:textStyle="italic" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- First Name row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="110dp"
                                android:layout_height="wrap_content"
                                android:text="First Name"
                                android:textColor="#2E7D32"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="20dp"
                                android:background="#DDDDDD"
                                android:layout_marginEnd="10dp" />

                            <TextView
                                android:id="@+id/tvFirstName"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="—"
                                android:textColor="#1A1A1A"
                                android:textSize="13sp"
                                android:singleLine="true"
                                android:ellipsize="end" />
                        </LinearLayout>

                        <!-- Middle Name row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="110dp"
                                android:layout_height="wrap_content"
                                android:text="Middle Name"
                                android:textColor="#2E7D32"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="20dp"
                                android:background="#DDDDDD"
                                android:layout_marginEnd="10dp" />

                            <TextView
                                android:id="@+id/tvMiddleName"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="—"
                                android:textColor="#1A1A1A"
                                android:textSize="13sp"
                                android:singleLine="true"
                                android:ellipsize="end" />
                        </LinearLayout>

                        <!-- Last Name row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="110dp"
                                android:layout_height="wrap_content"
                                android:text="Last Name"
                                android:textColor="#2E7D32"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="20dp"
                                android:background="#DDDDDD"
                                android:layout_marginEnd="10dp" />

                            <TextView
                                android:id="@+id/tvLastName"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="—"
                                android:textColor="#1A1A1A"
                                android:textSize="13sp"
                                android:singleLine="true"
                                android:ellipsize="end" />
                        </LinearLayout>

                        <!-- Mobile row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:layout_marginBottom="8dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/baseline_call_24"
                                android:tint="#2E7D32"
                                android:layout_marginEnd="6dp" />

                            <TextView
                                android:layout_width="94dp"
                                android:layout_height="wrap_content"
                                android:text="Mobile"
                                android:textColor="#2E7D32"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="20dp"
                                android:background="#DDDDDD"
                                android:layout_marginEnd="10dp" />

                            <TextView
                                android:id="@+id/tvMobile"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="—"
                                android:textColor="#1A1A1A"
                                android:textSize="13sp"
                                android:singleLine="true"
                                android:ellipsize="end" />
                        </LinearLayout>

                        <!-- Alternate row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:layout_marginBottom="8dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/baseline_call_24"
                                android:tint="#2E7D32"
                                android:layout_marginEnd="6dp" />

                            <TextView
                                android:layout_width="94dp"
                                android:layout_height="wrap_content"
                                android:text="Alternate"
                                android:textColor="#2E7D32"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="20dp"
                                android:background="#DDDDDD"
                                android:layout_marginEnd="10dp" />

                            <TextView
                                android:id="@+id/tvAlternate"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="—"
                                android:textColor="#1A1A1A"
                                android:textSize="13sp"
                                android:singleLine="true"
                                android:ellipsize="end" />
                        </LinearLayout>

                        <!-- Location row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/baseline_add_ic_call_24"
                                android:tint="#E53935"
                                android:layout_marginEnd="6dp" />

                            <TextView
                                android:layout_width="94dp"
                                android:layout_height="wrap_content"
                                android:text="Location"
                                android:textColor="#E53935"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="20dp"
                                android:background="#DDDDDD"
                                android:layout_marginEnd="10dp" />

                            <TextView
                                android:id="@+id/tvAddress"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="—"
                                android:textColor="#1A1A1A"
                                android:textSize="13sp"
                                android:singleLine="true"
                                android:ellipsize="end" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ CARD 3: TRANSACTION HISTORY ══ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- ── Clickable Card Header ── -->
                    <LinearLayout
                        android:id="@+id/headerTransactions"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_card_header_selector"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/baseline_article_24"
                            android:tint="#FFFFFF" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="Transaction History"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/ivArrowTransactions"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/outline_arrow_drop_down_24"
                            android:tint="#FFFFFF"
                            android:rotation="0" />
                    </LinearLayout>

                    <!-- ── Collapsible Body ── -->
                    <LinearLayout
                        android:id="@+id/bodyTransactions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <!-- Table Header -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:background="#E8F5E9"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.8"
                                android:text="Tr No"
                                android:textColor="#2E7D32"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1.4"
                                android:text="Type"
                                android:textColor="#2E7D32"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Fee"
                                android:textColor="#2E7D32"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:gravity="end" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Paid"
                                android:textColor="#2E7D32"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:gravity="end" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Rec No"
                                android:textColor="#2E7D32"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:gravity="end" />
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#E0E0E0" />

                        <!-- Transaction rows — inflated by Java -->
                        <LinearLayout
                            android:id="@+id/llTransactions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingBottom="8dp" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── LOADER OVERLAY ── -->
    <FrameLayout
        android:id="@+id/loaderLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
